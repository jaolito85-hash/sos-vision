# ──────────── PRODUÇÃO (demo pública via Coolify) ────────────
# Copie para .env no Coolify (ou nas variáveis do recurso) e preencha SEU_DOMINIO.
# Troque "app." e "api." pelos subdomínios que você criar no DNS.

# Banco (interno ao compose — não exponha publicamente)
POSTGRES_USER=sos
POSTGRES_PASSWORD=TROQUE_por_senha_forte
POSTGRES_DB=sosvision
DATABASE_URL=postgresql://sos:TROQUE_por_senha_forte@postgres:5432/sosvision
REDIS_URL=redis://redis:6379/0

# URLs públicas (HTTPS obrigatório)
PUBLIC_BASE_URL=https://api.SEU_DOMINIO        # backend/API
PUBLIC_APP_URL=https://app.SEU_DOMINIO         # Sala + PWAs
CORS_ORIGINS=https://app.SEU_DOMINIO

# Build da Sala (embutida no frontend em build time)
VITE_API=https://api.SEU_DOMINIO

# ──────────── WhatsApp: Evolution API (MVP) ────────────
# Pós-MVP: trocar para a Cloud API oficial (MESSAGING_CHANNEL=cloud + WHATSAPP_*).
MESSAGING_CHANNEL=evolution
EVOLUTION_URL=https://evo.SEU_DOMINIO
EVOLUTION_KEY=sua_apikey_do_evolution
EVOLUTION_INSTANCE=sosvision

# IA de triagem (opcional — sem isso usa o classificador heurístico)
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ──────────── WhatsApp Cloud API (pós-MVP — deixar vazio agora) ────────────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=troque-este-token
