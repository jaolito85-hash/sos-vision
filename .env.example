# ---- Banco / infra ----
DATABASE_URL=postgresql://sos:sos@postgres:5432/sosvision
REDIS_URL=redis://redis:6379/0

# ---- App ----
PUBLIC_BASE_URL=http://localhost:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5180,http://localhost:5181

# ---- WhatsApp Cloud API (Meta Business) ----
# Deixe vazio em dev para usar o canal "simulador".
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=troque-este-token
# Canal ativo: cloud | simulator
MESSAGING_CHANNEL=simulator

# ---- IA de triagem (opcional) ----
# Se vazio, usa classificador heurístico local.
ANTHROPIC_API_KEY=
CLASSIFIER_MODEL=claude-haiku-4-5-20251001

# ---- SMS fallback (stub) ----
SMS_PROVIDER=
SMS_API_KEY=
